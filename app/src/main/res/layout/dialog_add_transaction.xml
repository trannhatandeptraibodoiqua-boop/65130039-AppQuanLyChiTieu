<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm Giao Dịch Mới"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:textStyle="bold"
        android:textColor="#1E3C72"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/edtAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập số tiền (đ)"
        android:inputType="numberDecimal"
        android:textSize="16sp"
        android:paddingVertical="12dp"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Khoản Chi (-)"
            android:textColor="#E53935"
            android:buttonTint="#E53935"
            android:fontFamily="sans-serif-medium"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Khoản Thu (+)"
            android:textColor="#4CAF50"
            android:buttonTint="#4CAF50"
            android:fontFamily="sans-serif-medium" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn danh mục:"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#757575"
        android:layout_marginBottom="6dp"/>

    <Spinner
        android:id="@+id/spnCategory"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnDatePicker"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn ngày phát sinh"
        android:textColor="#1E3C72"
        android:fontFamily="sans-serif-medium"
        android:gravity="start|center_vertical"
        android:paddingVertical="12dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/edtNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ghi chú chi tiết (không bắt buộc)"
        android:inputType="textShortMessage"
        android:textSize="15sp"
        android:paddingVertical="12dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSaveTransaction"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="LƯU GIAO DỊCH"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="15sp" />
</LinearLayout>