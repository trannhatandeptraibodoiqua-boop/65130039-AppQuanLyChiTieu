<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F4F6F9"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Báo Cáo Tổng Quan"
    android:textSize="22sp"
    android:fontFamily="sans-serif-black"
    android:textStyle="bold"
    android:textColor="#1A237E"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="12dp"
    android:letterSpacing="0.01"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutReport"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/transparent"
        app:tabSelectedTextColor="#1E3C72"
        app:tabTextColor="#616161"
        app:tabIndicatorColor="#1E3C72"
        app:tabIndicatorHeight="3dp"
        app:tabGravity="fill"
        app:tabMode="fixed">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hàng Tháng" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hàng Năm" />
    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thời gian trước"
            android:tint="#424242"/>

        <TextView
            android:id="@+id/tvTimeDisplay"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Tháng 05/2026"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="#1E3C72"
            android:layout_marginHorizontal="16dp"
            android:elevation="1dp"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thời gian sau"
            android:tint="#424242"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="310dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp">

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvChartTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cấu trúc chi tiêu"
                android:textColor="#212121"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:paddingHorizontal="8dp"
            android:weightSum="2"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TỔNG THU NHẬP"
                    android:textColor="#757575"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/tvTotalIncome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ 0 VNĐ"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#E0E0E0"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TỔNG CHI TIÊU"
                    android:textColor="#757575"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"/>

                <TextView
                    android:id="@+id/tvTotalExpense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="- 0 VNĐ"
                    android:textColor="#C62828"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>