<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@android:drawable/list_selector_background">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toStartOf="@+id/tvItemAmount"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/tvItemCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Danh mục"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <TextView
            android:id="@+id/tvItemNoteAndDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ghi chú (Ngày/Tháng)"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvItemAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 đ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_toStartOf="@+id/btnDeleteTransaction"
        android:layout_centerVertical="true"
        android:layout_marginEnd="12dp"/>

    <ImageButton
        android:id="@+id/btnDeleteTransaction"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="?android:attr/selectableItemBackground"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="Xóa giao dịch" />

</RelativeLayout>